<article class="card{% if item.premium %} card-premium{% endif %}">
  {% if item.premium and item.premiumPhotos.length %}
    <div class="card-thumbnail">
      <a href="{{ item.url }}">
        <img src="/images/premium/{{ item.slug }}/{{ item.premiumPhotos[0] }}"
             alt="{{ item.name }}"
             loading="lazy"
             width="400" height="200">
      </a>
    </div>
  {% endif %}
  {% if item.premium %}
    <span class="featured-badge">Featured</span>
  {% endif %}
  <h3><a href="{{ item.url }}">{{ item.name }}</a></h3>
  {% if item.premium and item.premiumTagline %}
    <p class="card-tagline">{{ item.premiumTagline }}</p>
  {% endif %}
  <div class="card-meta">
    {{ item.city }}, PA {{ item.zip }}
    {% if item.google_rating %}
      {% include "components/star-rating.njk" %}
    {% endif %}
  </div>
  {% if item.phone %}
    <div class="card-phone">
      <a href="{{ item.phone | phone_link }}">{{ item.phone }}</a>
    </div>
  {% endif %}
  <div class="card-links">
    {% if item.website %}
      <a href="{{ item.website }}" target="_blank" rel="noopener">Website</a>
    {% endif %}
    {% if item.google_maps_url %}
      <a href="{{ item.google_maps_url }}" target="_blank" rel="noopener">Directions</a>
    {% endif %}
  </div>
</article>
